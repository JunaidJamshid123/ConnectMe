<?xml version="1.0" encoding="utf-8"?>
<!-- Shimmer skeleton for the search/explore page -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:orientation="vertical">

    <!-- ====== SEARCH BAR PLACEHOLDER ====== -->
    <View
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/shimmer_rounded_rect" />

    <!-- ====== EXPLORE GRID PLACEHOLDER ====== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Row 1: 3 small squares -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1"
                android:layout_margin="1dp"
                android:background="@drawable/shimmer_rounded_rect" />

            <View
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1"
                android:layout_margin="1dp"
                android:background="@drawable/shimmer_rounded_rect" />

            <View
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1"
                android:layout_margin="1dp"
                android:background="@drawable/shimmer_rounded_rect" />
        </LinearLayout>

        <!-- Row 2: 1 large square + 2 small stacked -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Large square (2x2) -->
            <View
                android:layout_width="0dp"
                android:layout_height="250dp"
                android:layout_weight="2"
                android:layout_margin="1dp"
                android:background="@drawable/shimmer_rounded_rect" />

            <!-- 2 small stacked squares -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="250dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_margin="1dp"
                    android:background="@drawable/shimmer_rounded_rect" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_margin="1dp"
                    android:background="@drawable/shimmer_rounded_rect" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 3: 3 small squares -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1"
                android:layout_margin="1dp"
                android:background="@drawable/shimmer_rounded_rect" />

            <View
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1"
                android:layout_margin="1dp"
                android:background="@drawable/shimmer_rounded_rect" />

            <View
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1"
                android:layout_margin="1dp"
                android:background="@drawable/shimmer_rounded_rect" />
        </LinearLayout>

        <!-- Row 4: 2 small stacked + 1 large square -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- 2 small stacked squares -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="250dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_margin="1dp"
                    android:background="@drawable/shimmer_rounded_rect" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_margin="1dp"
                    android:background="@drawable/shimmer_rounded_rect" />
            </LinearLayout>

            <!-- Large square (2x2) -->
            <View
                android:layout_width="0dp"
                android:layout_height="250dp"
                android:layout_weight="2"
                android:layout_margin="1dp"
                android:background="@drawable/shimmer_rounded_rect" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
