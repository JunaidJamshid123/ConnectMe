<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <!-- Camera/Gallery Preview -->
    <ImageView
        android:id="@+id/img_story_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <!-- Placeholder when no image selected -->
    <LinearLayout
        android:id="@+id/placeholder_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_add_photo"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Tap to select a photo"
            android:textColor="#AAAAAA"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_close"
            app:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Add to Story"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />

        <!-- Spacer to balance close button -->
        <View
            android:layout_width="28dp"
            android:layout_height="28dp" />
    </LinearLayout>

    <!-- Bottom Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp">

        <!-- Gallery Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_gallery"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:text="Choose from Gallery"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:cornerRadius="26dp"
            app:icon="@drawable/ic_add_photo"
            app:iconTint="@color/white"
            app:iconGravity="textStart"
            app:strokeColor="#55FFFFFF"
            app:strokeWidth="1dp" />

        <!-- Share Story Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share_story"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Share to Story"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:visibility="gone"
            app:backgroundTint="@color/instagram_blue"
            app:cornerRadius="26dp" />

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@color/white" />
    </LinearLayout>

</FrameLayout>
