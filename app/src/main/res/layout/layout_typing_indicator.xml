<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/typingIndicatorContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="4dp"
    android:visibility="gone">

    <!-- Profile Image -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/imgTypingProfile"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/default_profile" />

    <!-- Typing dots container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_typing_indicator"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <View
            android:id="@+id/typingDot1"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_typing_dot" />

        <View
            android:id="@+id/typingDot2"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_typing_dot" />

        <View
            android:id="@+id/typingDot3"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_typing_dot" />

    </LinearLayout>

</LinearLayout>
