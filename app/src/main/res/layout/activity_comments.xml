<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Drag Handle (Instagram style) -->
    <View
        android:id="@+id/drag_handle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_drag_handle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Title - Centered -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Comments"
        android:textColor="#262626"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/drag_handle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Close button (hidden, for back navigation) -->
    <ImageView
        android:id="@+id/back"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Close"
        android:src="@drawable/ic_close"
        android:visibility="gone"
        app:tint="#262626"
        app:layout_constraintTop_toTopOf="@id/title"
        app:layout_constraintBottom_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Share button -->
    <ImageView
        android:id="@+id/share"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Share"
        android:src="@drawable/ic_share"
        android:visibility="gone"
        app:tint="#262626"
        app:layout_constraintTop_toTopOf="@id/title"
        app:layout_constraintBottom_toBottomOf="@id/title"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Divider -->
    <View
        android:id="@+id/divider_top"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="12dp"
        android:background="#EFEFEF"
        app:layout_constraintTop_toBottomOf="@id/title" />

    <!-- Comments List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/comments_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:overScrollMode="never"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/divider_top"
        app:layout_constraintBottom_toTopOf="@id/emoji_bar" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/divider_top"
        app:layout_constraintBottom_toTopOf="@id/emoji_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No comments yet"
            android:textColor="#262626"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Start the conversation."
            android:textColor="#8E8E8E"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Emoji Quick Reactions Bar -->
    <HorizontalScrollView
        android:id="@+id/emoji_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/divider_bottom">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/emoji_heart"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="❤️"
                android:textSize="22sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_clap"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="👏"
                android:textSize="22sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_fire"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="🔥"
                android:textSize="22sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_thumbsup"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="👍"
                android:textSize="22sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_cry"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="😢"
                android:textSize="22sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_love"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="😍"
                android:textSize="22sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_laugh"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="🤣"
                android:textSize="22sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_wow"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="😮"
                android:textSize="22sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Bottom Divider -->
    <View
        android:id="@+id/divider_bottom"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#EFEFEF"
        app:layout_constraintBottom_toTopOf="@id/comment_input_container" />

    <!-- Comment Input Section -->
    <LinearLayout
        android:id="@+id/comment_input_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:minHeight="52dp"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Current User Profile Image -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/current_user_image"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/default_profile"
            app:civ_border_width="0dp" />

        <!-- Comment Input Container with rounded border -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_comment_input"
            android:gravity="center_vertical"
            android:minHeight="36dp"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <!-- Comment Input Field -->
            <EditText
                android:id="@+id/comment_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Add a comment..."
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:textColor="#262626"
                android:textColorHint="#8E8E8E"
                android:textSize="14sp" />

            <!-- GIF Button -->
            <TextView
                android:id="@+id/btn_gif"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_gif_button"
                android:gravity="center"
                android:paddingHorizontal="6dp"
                android:text="GIF"
                android:textColor="#8E8E8E"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <!-- Post Button -->
        <TextView
            android:id="@+id/btn_post_comment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackground"
            android:paddingHorizontal="4dp"
            android:paddingVertical="8dp"
            android:text="Post"
            android:textColor="#0095F6"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:alpha="0.5"
            android:enabled="false" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
