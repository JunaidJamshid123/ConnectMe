<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/background_primary">

    <ImageView
        android:id="@+id/iv_explore_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="@color/input_background"
        android:contentDescription="Explore post" />

    <!-- Video thumbnail (for video posts) -->
    <ImageView
        android:id="@+id/iv_video_thumbnail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="@color/input_background"
        android:visibility="gone"
        android:contentDescription="Video Thumbnail" />

    <!-- Video player view for playback -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/video_player"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:use_controller="false"
        app:resize_mode="zoom" />

    <!-- Video play icon overlay (center) -->
    <ImageView
        android:id="@+id/iv_video_icon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_play_circle"
        android:visibility="gone"
        app:tint="@android:color/white"
        android:contentDescription="Play video" />

    <!-- Video duration label (bottom right) -->
    <TextView
        android:id="@+id/tv_video_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="6dp"
        android:background="#80000000"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        android:visibility="gone" />

    <!-- Collections/carousel icon overlay (top-right) -->
    <ImageView
        android:id="@+id/iv_type_icon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_gravity="top|end"
        android:layout_margin="8dp"
        android:visibility="gone"
        android:contentDescription="Post type" />

</FrameLayout>
