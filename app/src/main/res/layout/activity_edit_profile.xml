<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    tools:context=".EditProfile">

    <!-- ====== TOP BAR ====== -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <!-- Cancel / Close -->
        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:fontFamily="sans-serif"
            android:text="Cancel"
            android:textColor="#262626"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="sans-serif-medium"
            android:text="Edit profile"
            android:textColor="#262626"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Done / Save (blue checkmark style) -->
        <TextView
            android:id="@+id/btn_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:fontFamily="sans-serif-medium"
            android:text="Done"
            android:textColor="#0095F6"
            android:textSize="16sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- Thin divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#DBDBDB" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ====== PROFILE PICTURE SECTION ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingBottom="16dp"
                android:paddingTop="20dp">

                <!-- Profile picture -->
                <FrameLayout
                    android:id="@+id/profile_image_container"
                    android:layout_width="96dp"
                    android:layout_height="96dp">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/profile_image"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_gravity="center"
                        android:scaleType="centerCrop"
                        android:src="@drawable/default_profile"
                        app:civ_border_color="#DBDBDB"
                        app:civ_border_width="0.5dp" />

                </FrameLayout>

                <!-- Change photo link -->
                <TextView
                    android:id="@+id/btn_change_photo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:fontFamily="sans-serif-medium"
                    android:text="Edit picture or avatar"
                    android:textColor="#0095F6"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Thin divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#DBDBDB" />

            <!-- ====== FORM FIELDS (Instagram-style inline) ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp">

                <!-- Name field -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="Name"
                        android:textColor="#8E8E8E"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/et_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:fontFamily="sans-serif"
                        android:hint="Name"
                        android:inputType="textPersonName"
                        android:minHeight="36dp"
                        android:paddingBottom="8dp"
                        android:paddingTop="4dp"
                        android:textColor="#262626"
                        android:textColorHint="#C7C7C7"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#DBDBDB" />

                </LinearLayout>

                <!-- Username field -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="Username"
                        android:textColor="#8E8E8E"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/et_username"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:fontFamily="sans-serif"
                        android:hint="Username"
                        android:inputType="text"
                        android:minHeight="36dp"
                        android:paddingBottom="8dp"
                        android:paddingTop="4dp"
                        android:textColor="#262626"
                        android:textColorHint="#C7C7C7"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#DBDBDB" />

                </LinearLayout>

                <!-- Pronouns field (Instagram style) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="Pronouns"
                        android:textColor="#8E8E8E"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/et_pronouns"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:fontFamily="sans-serif"
                        android:hint="Pronouns"
                        android:inputType="text"
                        android:minHeight="36dp"
                        android:paddingBottom="8dp"
                        android:paddingTop="4dp"
                        android:textColor="#262626"
                        android:textColorHint="#C7C7C7"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#DBDBDB" />

                </LinearLayout>

                <!-- Bio field -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="Bio"
                        android:textColor="#8E8E8E"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/et_bio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:fontFamily="sans-serif"
                        android:gravity="top|start"
                        android:hint="Bio"
                        android:inputType="textMultiLine"
                        android:minHeight="36dp"
                        android:minLines="1"
                        android:paddingBottom="8dp"
                        android:paddingTop="4dp"
                        android:textColor="#262626"
                        android:textColorHint="#C7C7C7"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#DBDBDB" />

                </LinearLayout>

                <!-- Links section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="Links"
                        android:textColor="#8E8E8E"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/btn_add_links"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:minHeight="36dp"
                        android:gravity="center_vertical"
                        android:paddingTop="4dp"
                        android:paddingBottom="8dp"
                        android:text="Add links"
                        android:textColor="#0095F6"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#DBDBDB" />

                </LinearLayout>

                <!-- Gender -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="Gender"
                        android:textColor="#8E8E8E"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tv_gender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:gravity="center_vertical"
                        android:minHeight="36dp"
                        android:paddingBottom="8dp"
                        android:paddingTop="4dp"
                        android:text="Prefer not to say"
                        android:textColor="#262626"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#DBDBDB" />

                </LinearLayout>

                <!-- Phone field -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="Phone"
                        android:textColor="#8E8E8E"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/et_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:fontFamily="sans-serif"
                        android:hint="Phone"
                        android:inputType="phone"
                        android:minHeight="36dp"
                        android:paddingBottom="8dp"
                        android:paddingTop="4dp"
                        android:textColor="#262626"
                        android:textColorHint="#C7C7C7"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#DBDBDB" />

                </LinearLayout>

            </LinearLayout>

            <!-- ====== BOTTOM SECTION ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="32dp">

                <TextView
                    android:id="@+id/btn_professional_account"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:fontFamily="sans-serif"
                    android:paddingVertical="6dp"
                    android:text="Switch to professional account"
                    android:textColor="#0095F6"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/btn_personal_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:fontFamily="sans-serif"
                    android:paddingVertical="6dp"
                    android:text="Personal information settings"
                    android:textColor="#0095F6"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>